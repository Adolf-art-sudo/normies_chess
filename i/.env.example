# Vercel Postgres creates these automatically when you connect storage.
POSTGRES_URL=

# Required in production. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Production domain only, no protocol. Example: normies-chess.vercel.app
SIWE_DOMAIN=localhost:3000

# Optional admin-only migration protection. Generate with: openssl rand -hex 24
ADMIN_SETUP_TOKEN=

# Public app URL. In Vercel set this to https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
